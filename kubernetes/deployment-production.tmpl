---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: bajor-production-app
  labels:
    app: bajor-production-app
spec:
  replicas: 1
  selector:
    matchLabels:
      app: bajor-production-app
  template:
    metadata:
      labels:
        app: bajor-production-app
    spec:
      containers:
        - name: bajor-production-app
          image: ghcr.io/zooniverse/bajor:__IMAGE_TAG__
          resources:
            requests:
              memory: "100Mi"
              cpu: "100m"
            limits:
              memory: "1000Mi"
              cpu: "1000m"
          startupProbe:
            httpGet:
              path: /
              port: 80
          livenessProbe:
            httpGet:
              path: /
              port: 80
            # allow a longer response time than 1s
            timeoutSeconds: 10
          readinessProbe:
            httpGet:
              path: /
              port: 80
            # allow a longer response time than 1s
            timeoutSeconds: 10
          env:
          - name: HONEYBADGER_ENVIRONMENT
            value: 'production'
          - name: PORT
            value: '80'
          - name: LOG_LEVEL
            value: 'INFO'
          - name: TRAINING_RUN_OPTS
            value: '--wandb'
          envFrom:
          - secretRef:
              name: bajor-common-env-vars
          - secretRef:
              name: bajor-production-api-env-vars
---
apiVersion: v1
kind: Service
metadata:
  name: bajor-production-app
spec:
  selector:
    app: bajor-production-app
  ports:
    - protocol: TCP
      port: 80
      targetPort: 80
---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: bajor-production-ingressroute
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`bajor.zooniverse.org`)
      kind: Rule
      services:
        - name: bajor-production-app
          port: 80
  tls:
    secretName: zooniverse-org-tls
